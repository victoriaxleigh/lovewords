{
  "name": "lovewords",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "icons": "node scripts/generate-icons.js",
    "build:web": "node scripts/generate-icons.js && expo export --platform web && node scripts/inject-web-meta.js",
    "test": "jest --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "json"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/engine/**/*.ts"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@supabase/supabase-js": "^2.105.1",
    "expo": "~54.0.33",
    "expo-constants": "^55.0.15",
    "expo-device": "^55.0.15",
    "expo-notifications": "^55.0.22",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.0",
    "react-onesignal": "^3.5.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "sharp": "^0.35.3",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
